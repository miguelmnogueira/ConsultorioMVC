@model IEnumerable<ConsultorioMVC.Models.PacienteView>

@{
    ViewData["Title"] = "Index";
}

<h1 class="fw-medium">Lista de Pacientes</h1>

<p>
    <a class="btn btn-primary" asp-action="CriarPaciente">Criar +</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Nome)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Cpf)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @item.Id
            </td>
            <td>
                @item.Nome
            </td>
            <td>
                @item.Email
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Cpf)
            </td>
            <td>
                <a href="/Pacientes/EditarPaciente/@item.Id" class="btn btn-sm btn-warning">Editar</a>
                <a href="/Pacientes/DeletarPaciente/@item.Id" class="btn btn-sm btn-danger">Excluir</a>
            </td>
        </tr>
}
    </tbody>
</table>
