@model ConsultorioMVC.Models.MedicoView

<h1>Criar Médico</h1>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="CriarMedico" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Nome" class="form-label"></label>
                <input asp-for="Nome" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Crm" class="form-label"></label>
                <input asp-for="Crm" class="form-control" />
            </div>
            <div class="mb-3">
                <select asp-for="ConsultorioId">
                    @foreach (var c in ViewBag.Consultorios)
                    {
                     <option value="@c.Id">@c.Nome</option>   
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-primary">Salvar</button>
            <a asp-action="Index" class="btn btn-secondary">Voltar</a>
        </form>
    </div>
</div>